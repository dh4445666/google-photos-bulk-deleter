{
  "manifest_version": 3,
  "name": "Google Photos Bulk Deleter",
  "version": "1.0",
  "description": "Bulk delete all your Google Photos in one click — no coding needed.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://photos.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
